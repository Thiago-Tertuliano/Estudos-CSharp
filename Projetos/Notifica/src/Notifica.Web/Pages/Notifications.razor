@page "/notifications"
@attribute [Authorize]
@inject Services.ApiService Api

<div class="container">
    <h2>Notifica&ccedil;&otilde;es</h2>
    @if (_notifications.Count == 0)
    {
        <div class="alert alert-info">Nenhuma notifica&ccedil;&atilde;o.</div>
    }
    @foreach (var n in _notifications)
    {
        <div class="card mb-2 @(n.IsRead ? "border-light" : "border-primary")">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <h6 class="mb-1">@n.Title</h6>
                    <p class="mb-0 text-muted small">@n.Message</p>
                    <small class="text-muted">@n.CreatedAt.ToLocalTime().ToString("g")</small>
                </div>
                @if (!n.IsRead)
                {
                    <button class="btn btn-sm btn-outline-primary" @onclick="() => MarkRead(n.Id)">Ler</button>
                }
            </div>
        </div>
    }
</div>

@code {
    private List<NotificationDto> _notifications = [];

    protected override async Task OnInitializedAsync()
    {
        _notifications = await Api.GetNotificationsAsync();
    }

    private async Task MarkRead(Guid id)
    {
        await Api.MarkNotificationReadAsync(id);
        var n = _notifications.FirstOrDefault(x => x.Id == id);
        if (n is not null)
        {
            _notifications.Remove(n);
            _notifications.Insert(0, n with { IsRead = true });
        }
    }
}
